    "AZURE_REDIRECT_URI": "http://localhost:3000",
    "CORS_ORIGINS": "http://localhost:3000,http://localhost:8000",
    
    "EXPERT_REVIEW_ENABLED": "true",
    "EXPERT_NOTIFICATION_EMAIL": "experts@vimarsh.ai",
    
    "ADMIN_EMAILS": "vedprakash.m@outlook.com",
    "SUPER_ADMIN_EMAILS": "vedprakash.m@outlook.com",
    "DEFAULT_MONTHLY_BUDGET": "50.0",
    "DEFAULT_DAILY_BUDGET": "5.0",
    "DEFAULT_REQUEST_BUDGET": "0.50",
    
    "ADMIN_FUNCTION_KEY": "dev-admin-key-replace-in-production",
